<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io">
  <diagram name="炼厂管理-新增编辑操作流程图" id="refinery-mgmt-flow">
    <mxGraphModel dx="700" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- 透明占位：撑开画布边界，提供内边距 -->
        <mxCell id="spacer" value="" style="fillColor=none;strokeColor=none;opacity=0;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="640" height="830" as="geometry"/>
        </mxCell>

        <!-- 开始 -->
        <mxCell id="n_start" value="开始" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="60" width="120" height="40" as="geometry"/>
        </mxCell>

        <!-- 步骤1 -->
        <mxCell id="n_enter" value="进入炼厂管理页面" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="190" y="150" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- 步骤2 -->
        <mxCell id="n_click_add" value="点击新增/编辑按钮" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="190" y="240" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- 步骤3 -->
        <mxCell id="n_fill_form" value="填写炼厂信息表单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="190" y="330" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- 步骤4 -->
        <mxCell id="n_submit" value="点击提交" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="190" y="420" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- 判断 -->
        <mxCell id="n_validate" value="校验通过？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="510" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- 否：提示错误（右侧） -->
        <mxCell id="n_error" value="提示错误信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="410" y="520" width="120" height="40" as="geometry"/>
        </mxCell>

        <!-- 是：保存成功 -->
        <mxCell id="n_success" value="保存成功，刷新列表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="190" y="630" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- 结束 -->
        <mxCell id="n_end" value="结束" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="730" width="120" height="40" as="geometry"/>
        </mxCell>

        <!-- === 连线 === -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_start" target="n_enter" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_enter" target="n_click_add" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_click_add" target="n_fill_form" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_fill_form" target="n_submit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_submit" target="n_validate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 是：底部出 → 保存成功 -->
        <mxCell id="e6" value="是" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=11;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_validate" target="n_success" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 否：右侧出 → 提示错误 -->
        <mxCell id="e7" value="否" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=11;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n_validate" target="n_error" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 错误回路：右侧出，向上绕回填写表单右侧入 -->
        <mxCell id="e8" value="修改后重新提交" style="edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n_error" target="n_fill_form" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="570" y="540"/><mxPoint x="570" y="350"/></Array>
          </mxGeometry>
        </mxCell>
        <!-- 保存成功 → 结束 -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n_success" target="n_end" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>