# 生产部署环境变量模板
# 复制为 .env 并替换所有占位值后再部署：cp .env.example .env

# 镜像地址（由 GitHub Actions 构建并推送到 GHCR，镜像名全小写）
# 本仓库对应：
#   BACKEND_IMAGE=ghcr.io/qingzhongxing60-cmd/zuopinsg-backend:latest
#   FRONTEND_IMAGE=ghcr.io/qingzhongxing60-cmd/zuopinsg-frontend:latest   # admin 后台
#   WEBSITE_IMAGE=ghcr.io/qingzhongxing60-cmd/zuopinsg-website:latest     # 前台主站
BACKEND_IMAGE=ghcr.io/qingzhongxing60-cmd/zuopinsg-backend:latest
FRONTEND_IMAGE=ghcr.io/qingzhongxing60-cmd/zuopinsg-frontend:latest
WEBSITE_IMAGE=ghcr.io/qingzhongxing60-cmd/zuopinsg-website:latest

# 数据库配置（请改为强密码）
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=agentpm
MYSQL_USER=agentpm
MYSQL_PASSWORD=change_me_db
MYSQL_PORT=3306

# Redis 配置（请改为强密码）
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379

# 后端配置
BACKEND_PORT=9001

# 端口配置
# 前台主站 website（对外 80/443）
HTTP_PORT=80
HTTPS_PORT=443
# admin 后台管理端（默认 8080，通过 http://服务器IP:8080 访问）
ADMIN_PORT=8080

# JWT（上线前必须替换为强随机值）
JWT_SECRET=change_me_to_a_strong_random_secret
